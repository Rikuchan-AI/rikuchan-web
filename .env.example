NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Configure the gateway with the same Clerk app:
# RIKUCHAN_CLERK_PUBLISHABLE_KEY=<same publishable key>
# RIKUCHAN_CLERK_SECRET_KEY=<same secret key if required by your backend flows>
# RIKUCHAN_CLERK_WEBHOOK_SECRET=<from Clerk webhook configuration>
# Clerk webhook endpoint on the gateway: https://<gateway-url>/webhooks/clerk

# Mission Control — set to "true" to enable agents, chat, knowledge base, and gateway features
NEXT_PUBLIC_MC_ENABLED=false
# NEXT_PUBLIC_MC_BACKEND_URL=https://your-mc-backend.railway.app
# MC_BACKEND_URL=https://your-mc-backend.railway.app
